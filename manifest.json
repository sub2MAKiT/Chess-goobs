{
  "manifest_version": 3,
  "name": "Goobas",
  "version": "1.0",

  "description": "replaces chess.com pieces with ALMatter goobers",

  "icons": {
    "48": "goobs/W/2.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "make.it@makit.wtf",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "js": ["goob.js"]
    }
  ]
}